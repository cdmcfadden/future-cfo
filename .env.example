# Anthropic — powers the /chat interface
ANTHROPIC_API_KEY=sk-ant-...

# Resend — powers the subscribe form + welcome email + post broadcasts
RESEND_API_KEY=re_...
# Create a segment at https://resend.com/segments and paste the id here
RESEND_SEGMENT_ID=
# Sender address. Must be at a domain verified in Resend → Domains.
# Friendly-name format supported: "Chris McFadden <hello@futurecfo.ai>"
RESEND_FROM="futurecfo.ai <hello@futurecfo.ai>"

# Site
NEXT_PUBLIC_SITE_URL=https://futurecfo.ai
